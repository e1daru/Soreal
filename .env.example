# Local host-facing defaults.
# Docker Compose overrides the app container's internal service URLs automatically.

SURREAL_URL=ws://localhost:8000/rpc
SURREAL_USERNAME=root
SURREAL_PASSWORD=root
SURREAL_NAMESPACE=soreal
SURREAL_DATABASE=kg

OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=soreal-kg-agent
LANGCHAIN_API_KEY=
